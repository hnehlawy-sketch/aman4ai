rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - mobile: string
    //   - isPremium: boolean
    //   - plan: string (free, pro, premium)
    //   - lastLogin: string (ISO date)
    //
    // Collection: users/{userId}/chats
    // Document ID: {chatId}
    // Fields:
    //   - id: string (required)
    //   - title: string
    //   - messages: list (required)
    //   - timestamp: number
    //
    // Collection: logs
    // Document ID: {logId}
    // Fields:
    //   - uid: string
    //   - email: string
    //   - type: string
    //   - content: map
    //   - timestamp: timestamp
    //   - tokens: number
    //   - metadata: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "h.nehlawy@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('isPremium' in data) || data.isPremium is bool) &&
             (!('role' in data) || data.role in ['user']);
    }

    function isValidPaymentRequest(data) {
      return data.keys().hasAll(['uid', 'email', 'status', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.plan in ['free', 'pro', 'premium'] &&
             (!('amount' in data) || data.amount is number) &&
             (!('currency' in data) || data.currency is string);
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'messages']) &&
             data.id is string &&
             data.messages is list &&
             (!('title' in data) || (data.title is string && data.title.size() < 200));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['type', 'timestamp']) &&
             data.type is string &&
             (data.timestamp is timestamp || data.timestamp is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable system configurations
    match /settings/system {
      allow read: if true;
    }
    match /settings/pricing {
      allow read: if true;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /payment_methods/{methodId} {
      allow read: if true;
      allow write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user')) || isAdmin();
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
      
      match /chats {
        allow list: if isOwner(userId) || isAdmin();
      }
      match /chats/{chatId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && isValidChat(request.resource.data)) || isAdmin();
        allow update: if (isOwner(userId) && isValidChat(request.resource.data)) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if (isAuthenticated() && isValidLog(request.resource.data)) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /payment_requests/{requestId} {
      allow read: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
      allow create: if (isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidPaymentRequest(request.resource.data) && request.resource.data.status == 'pending') || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny for others, but allow admin everywhere
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
